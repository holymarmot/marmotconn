{
  "name": "marmotconn",
  "version": "1.0.0",
  "description": "Gitea için minimal modern Git GUI istemcisi",
  "author": {
    "name": "Holy Marmot",
    "email": "contact@holymarmot.com"
  },
  "homepage": "https://github.com/holymarmot/marmotconn",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "electron": "electron .",
    "electron:dev": "wait-on http://localhost:5173 && cross-env ELECTRON_DEV=true electron .",
    "start": "concurrently \"npm run dev:renderer\" \"npm run electron:dev\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --win --mac --linux"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "diff2html": "^3.4.47",
    "electron-store": "^8.1.0",
    "i18next": "^26.0.6",
    "lucide-react": "^1.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.4",
    "simple-git": "^3.22.0",
    "ssh2": "^1.15.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/ssh2": "^1.11.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^29.1.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.marmotconn.app",
    "productName": "Marmotconn",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "afterPack": "./scripts/afterPack.js",
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Marmotconn",
      "installerSidebar": null,
      "license": null,
      "artifactName": "${productName}-Setup-${version}-win-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-${arch}-portable.${ext}"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": [
        { "target": "zip", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "Development",
      "description": "A minimal Git GUI client for Gitea"
    },
    "deb": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "rpm": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": ["**/*"]
      }
    ]
  }
}
